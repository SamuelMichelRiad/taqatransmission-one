function oneservices_node_view_alter(
  array &$build,
  EntityInterface $entity,
  EntityViewDisplayInterface $display,
) {

  if($entity->bundle() == 'notification') {
    $build['#cache']['max-age'] = 0;
    \Drupal::service('page_cache_kill_switch')->trigger();

    $user = User::load(\Drupal::currentUser()->id());
    $is_notification_manager = in_array('notification_manager', $user->getRoles());
    if($is_notification_manager) {
      $build['send_notification'] = [
        '#type' => 'link',
        '#title' => 'Send notification',
        '#url' => Url::fromRoute(
          'oneservices.send_notification',
            ['node' => $entity->id()],
        ),
        '#attributes' => [ 'class' => [ 'button', 'button--primary' ] ] 
      ];
    } 
  }
}
