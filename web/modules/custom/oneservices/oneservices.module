<?php

use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\user\Entity\User;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;
use Drupal\taxonomy\TermInterface;
use Drupal\Core\Database\Database;

function oneservices_node_insert(NodeInterface $node): void {
  if($node->bundle() == 'notification' || $node->bundle() == 'service') {
    $url  = 'http://localhost:3000/hooks/refresh/' . $node->bundle().'s';
    try {
      \Drupal::httpClient()->post($url, [
        'timeout'     => 3,
        'http_errors' => FALSE,
        'headers'     => ['Content-Type' => 'application/json'],
        'json'        => (object)[], // empty JSON body
      ]);
    } catch (\Throwable $e) {
      \Drupal::logger('oneservices')->error('Webhook POST failed (@type): @msg', [
        '@type' => $type,
        '@msg'  => $e->getMessage(),
      ]);
    }
  }
}

function oneservices_node_update(NodeInterface $node): void {
  if($node->bundle() == 'notification' || $node->bundle() == 'service') {
    /** @var \Drupal\Core\Database\Transaction\TransactionManagerInterface $tm */
    $tm = \Drupal::service('database.transaction_manager');
    if ($tm->inTransaction()) {
      $tm->addPostTransactionCallback(function (bool $success) {
        $url  = 'http://localhost:3000/hooks/refresh/' . $node->bundle().'s';
        try {
          \Drupal::httpClient()->post($url, [
            'timeout'     => 3,
            'http_errors' => FALSE,
            'headers'     => ['Content-Type' => 'application/json'],
            'json'        => (object)[], // empty JSON body
          ]);
        } catch (\Throwable $e) {
          \Drupal::logger('oneservices')->error('Webhook POST failed (@type): @msg', [
            '@type' => $type,
            '@msg'  => $e->getMessage(),
          ]);
        }
      });
    }
  }
}

function oneservices_node_delete(NodeInterface $node): void {
  if($node->bundle() == 'notification' || $node->bundle() == 'service') {
    $url  = 'http://localhost:3000/hooks/refresh/' . $node->bundle().'s';
    try {
      \Drupal::httpClient()->post($url, [
        'timeout'     => 3,
        'http_errors' => FALSE,
        'headers'     => ['Content-Type' => 'application/json'],
        'json'        => (object)[], // empty JSON body
      ]);
    } catch (\Throwable $e) {
      \Drupal::logger('oneservices')->error('Webhook POST failed (@type): @msg', [
        '@type' => $type,
        '@msg'  => $e->getMessage(),
      ]);
    }
  }
}


function oneservices_taxonomy_term_insert(TermInterface $term): void {
  // Limit to a vocabulary if needed:
  if ($term->bundle() === 'category') { 
    $url  = 'http://localhost:3000/hooks/refresh/categories';
    try {
      \Drupal::httpClient()->post($url, [
        'timeout'     => 3,
        'http_errors' => FALSE,
        'headers'     => ['Content-Type' => 'application/json'],
        'json'        => (object)[], // empty JSON body
      ]);
    } catch (\Throwable $e) {
      \Drupal::logger('oneservices')->error('Webhook POST failed (@type): @msg', [
        '@type' => $type,
        '@msg'  => $e->getMessage(),
      ]);
    }
  }
}

